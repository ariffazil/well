# WELL — Human Readiness MCP Server
# Quickstart environment template. Copy to .env and fill in your values.
# See https://github.com/ariffazil/arifOS for the constitutional framework.

# ── Server ──────────────────────────────────────────────────────────
WELL_HOST=0.0.0.0
WELL_PORT=8083
WELL_PUBLIC_BASE_URL=http://localhost:8083

# ── Sovereign Identity (required for F11 Auth) ──────────────────────
# Point to your identity.toml or configure inline.
# identity.toml format: { "sovereign": "your-name", "authority": "F13" }

# ── Biometric State ─────────────────────────────────────────────────
# Path to state.json for sovereign human readiness data.
# If absent, WELL runs in mock/test mode.
WELL_STATE_PATH=./state.json

# ── Quick Start ─────────────────────────────────────────────────────
#   pip install -e .
#   cp .env.example .env
#   python server.py
#   curl http://localhost:8083/health
