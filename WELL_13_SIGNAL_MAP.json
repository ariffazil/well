    "recovery_metabolic": {
      "label": "Tier 2 — Recovery / Metabolic",
      "principle": "Recovery precedes function.",
      "authority": "reflect_only"
    },
    "function_cognition": {
      "label": "Tier 3 — Function / Cognition",
      "principle": "What the body can do under current load.",
      "authority": "reflect_only"
    },
    "dignity_environment": {
      "label": "Tier 4 — Dignity / Environment",
      "principle": "The layer fitness apps never see. The differentiator.",
      "authority": "reflect_only"
    }
  },

